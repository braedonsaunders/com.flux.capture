<?xml version="1.0" encoding="UTF-8"?>
<customlist scriptid="customlist_dm_batch_status">
    <name>DM Batch Status</name>
    <description>Status values for Flux Capture batches</description>
    <isordered>T</isordered>
    <customvalues>
        <customvalue scriptid="custval_pending">
            <value>Pending</value>
        </customvalue>
        <customvalue scriptid="custval_processing">
            <value>Processing</value>
        </customvalue>
        <customvalue scriptid="custval_completed">
            <value>Completed</value>
        </customvalue>
        <customvalue scriptid="custval_partial_error">
            <value>Partial Error</value>
        </customvalue>
        <customvalue scriptid="custval_failed">
            <value>Failed</value>
        </customvalue>
        <customvalue scriptid="custval_cancelled">
            <value>Cancelled</value>
        </customvalue>
    </customvalues>
</customlist>
