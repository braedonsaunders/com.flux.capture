<?xml version="1.0" encoding="UTF-8"?>
<customrecordtype scriptid="customrecord_dm_learning">
    <recordname>DM Learning Record</recordname>
    <includename>T</includename>
    <showid>T</showid>
    <shownotes>F</shownotes>
    <allowattachments>F</allowattachments>
    <allowinlineediting>F</allowinlineediting>
    <allowinlinedeleting>T</allowinlinedeleting>
    <allowquicksearch>T</allowquicksearch>
    <hierarchical>F</hierarchical>
    <enablenumbering>F</enablenumbering>
    <enablekeywords>F</enablekeywords>
    <isordered>F</isordered>
    <description>Flux Capture Learning - Stores user corrections for ML improvement</description>

    <customrecordcustomfields>
        <customrecordcustomfield scriptid="custrecord_dm_learn_vendor">
            <fieldtype>SELECT</fieldtype>
            <label>Vendor</label>
            <description>Associated vendor</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
            <selectrecordtype>-4</selectrecordtype>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_document">
            <fieldtype>SELECT</fieldtype>
            <label>Source Document</label>
            <description>Original captured document</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
            <selectrecordtype>[scriptid=customrecord_dm_captured_document]</selectrecordtype>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_field">
            <fieldtype>TEXT</fieldtype>
            <label>Field Name</label>
            <description>Name of field that was corrected</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_original">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Original Value</label>
            <description>AI-extracted value</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_corrected">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Corrected Value</label>
            <description>User-corrected value</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_corrections">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Corrections</label>
            <description>All corrections as JSON</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_pattern">
            <fieldtype>TEXT</fieldtype>
            <label>Pattern</label>
            <description>Learned pattern (regex or keyword)</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_count">
            <fieldtype>INTEGER</fieldtype>
            <label>Occurrence Count</label>
            <description>Number of times this correction occurred</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_date">
            <fieldtype>DATETIMETZ</fieldtype>
            <label>Date</label>
            <description>Date correction was made</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_dm_learn_user">
            <fieldtype>SELECT</fieldtype>
            <label>Corrected By</label>
            <description>User who made correction</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
            <selectrecordtype>-4</selectrecordtype>
        </customrecordcustomfield>
    </customrecordcustomfields>
</customrecordtype>
