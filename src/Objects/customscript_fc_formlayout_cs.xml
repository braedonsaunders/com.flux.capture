<?xml version="1.0" encoding="UTF-8"?>
<clientscript scriptid="customscript_fc_formlayout_cs">
    <name>Flux Capture Form Layout Capture</name>
    <scriptfile>[/SuiteApps/com.flux.capture/scripts/FC_FormLayoutCapture_CS.js]</scriptfile>
    <description>Automatically extracts form layout (tabs, groups, fields, visibility) from transaction forms and caches for Flux Capture</description>
    <isinactive>F</isinactive>
    <notifyadmins>F</notifyadmins>
    <notifyemails></notifyemails>
    <notifyowner>F</notifyowner>
    <scriptdeployments>
        <!-- Vendor Bill Deployment -->
        <scriptdeployment scriptid="customdeploy_fc_formlayout_vendorbill">
            <status>RELEASED</status>
            <title>FC Layout Capture - Vendor Bill</title>
            <isdeployed>T</isdeployed>
            <loglevel>ERROR</loglevel>
            <allroles>T</allroles>
            <recordtype>VENDOR_BILL</recordtype>
        </scriptdeployment>
        <!-- Expense Report Deployment -->
        <scriptdeployment scriptid="customdeploy_fc_formlayout_expense">
            <status>RELEASED</status>
            <title>FC Layout Capture - Expense Report</title>
            <isdeployed>T</isdeployed>
            <loglevel>ERROR</loglevel>
            <allroles>T</allroles>
            <recordtype>EXPENSE_REPORT</recordtype>
        </scriptdeployment>
        <!-- Purchase Order Deployment -->
        <scriptdeployment scriptid="customdeploy_fc_formlayout_po">
            <status>RELEASED</status>
            <title>FC Layout Capture - Purchase Order</title>
            <isdeployed>T</isdeployed>
            <loglevel>ERROR</loglevel>
            <allroles>T</allroles>
            <recordtype>PURCHASE_ORDER</recordtype>
        </scriptdeployment>
    </scriptdeployments>
</clientscript>
