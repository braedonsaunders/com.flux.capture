<?xml version="1.0" encoding="UTF-8"?>
<customlist scriptid="customlist_dm_status">
    <name>DM Document Status</name>
    <description>Status values for Flux Capture captured documents</description>
    <isordered>T</isordered>
    <customvalues>
        <customvalue scriptid="custval_pending">
            <value>Pending</value>
        </customvalue>
        <customvalue scriptid="custval_processing">
            <value>Processing</value>
        </customvalue>
        <customvalue scriptid="custval_extracted">
            <value>Extracted</value>
        </customvalue>
        <customvalue scriptid="custval_needs_review">
            <value>Needs Review</value>
        </customvalue>
        <customvalue scriptid="custval_approved">
            <value>Approved</value>
        </customvalue>
        <customvalue scriptid="custval_rejected">
            <value>Rejected</value>
        </customvalue>
        <customvalue scriptid="custval_completed">
            <value>Completed</value>
        </customvalue>
        <customvalue scriptid="custval_error">
            <value>Error</value>
        </customvalue>
    </customvalues>
</customlist>
