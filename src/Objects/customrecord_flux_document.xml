<?xml version="1.0" encoding="UTF-8"?>
<customrecordtype scriptid="customrecord_flux_document">
    <recordname>Flux Document</recordname>
    <includename>F</includename>
    <showid>T</showid>
    <shownotes>T</shownotes>
    <allowattachments>T</allowattachments>
    <allowinlineediting>T</allowinlineediting>
    <allowinlinedeleting>F</allowinlinedeleting>
    <allowquicksearch>T</allowquicksearch>
    <hierarchical>F</hierarchical>
    <enablenumbering>F</enablenumbering>
    <enablekeywords>T</enablekeywords>
    <isordered>F</isordered>
    <description>Flux Capture Document - Stores captured documents with extraction data</description>

    <customrecordcustomfields>
        <customrecordcustomfield scriptid="custrecord_flux_source_file">
            <fieldtype>DOCUMENT</fieldtype>
            <label>Source File</label>
            <description>The original uploaded document file</description>
            <ismandatory>T</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_document_id">
            <fieldtype>TEXT</fieldtype>
            <label>Document ID</label>
            <description>Unique identifier for this document</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_original_filename">
            <fieldtype>TEXT</fieldtype>
            <label>Original Filename</label>
            <description>Original name of the uploaded file</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_document_type">
            <fieldtype>INTEGER</fieldtype>
            <label>Document Type</label>
            <description>Type of document: 1=Invoice, 2=Receipt, 3=Credit Memo, 4=Expense Report, 5=Purchase Order, 6=Unknown</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_status">
            <fieldtype>INTEGER</fieldtype>
            <label>Status</label>
            <description>Processing status: 1=Pending, 2=Processing, 3=Extracted, 4=Needs Review, 5=Rejected, 6=Completed, 7=Error</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_vendor">
            <fieldtype>SELECT</fieldtype>
            <label>Vendor</label>
            <description>Matched vendor</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
            <selectrecordtype>-3</selectrecordtype>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_vendor_match_conf">
            <fieldtype>PERCENT</fieldtype>
            <label>Vendor Match Confidence</label>
            <description>Confidence level of vendor match</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_invoice_number">
            <fieldtype>TEXT</fieldtype>
            <label>Invoice Number</label>
            <description>Extracted invoice/reference number</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_invoice_date">
            <fieldtype>DATE</fieldtype>
            <label>Invoice Date</label>
            <description>Extracted invoice date</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_due_date">
            <fieldtype>DATE</fieldtype>
            <label>Due Date</label>
            <description>Extracted payment due date</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_subtotal">
            <fieldtype>CURRENCY</fieldtype>
            <label>Subtotal</label>
            <description>Extracted subtotal amount</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_tax_amount">
            <fieldtype>CURRENCY</fieldtype>
            <label>Tax Amount</label>
            <description>Extracted tax amount</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_total_amount">
            <fieldtype>CURRENCY</fieldtype>
            <label>Total Amount</label>
            <description>Extracted total amount</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_currency">
            <fieldtype>SELECT</fieldtype>
            <label>Currency</label>
            <description>Document currency</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
            <selectrecordtype>-122</selectrecordtype>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_po_number">
            <fieldtype>TEXT</fieldtype>
            <label>PO Number</label>
            <description>Extracted purchase order number</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_payment_terms">
            <fieldtype>TEXT</fieldtype>
            <label>Payment Terms</label>
            <description>Payment terms</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_line_items">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Line Items</label>
            <description>Extracted line items as JSON</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_confidence_score">
            <fieldtype>PERCENT</fieldtype>
            <label>Confidence Score</label>
            <description>Overall extraction confidence</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_anomalies">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Anomalies</label>
            <description>Detected anomalies as JSON</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_amount_validated">
            <fieldtype>CHECKBOX</fieldtype>
            <label>Amount Validated</label>
            <description>Whether line items match total</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_source">
            <fieldtype>INTEGER</fieldtype>
            <label>Source</label>
            <description>How document was uploaded: 1=Upload, 2=Email, 3=Drag/Drop, 4=API, 5=Scanner, 6=Mobile</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_created_transaction">
            <fieldtype>TEXT</fieldtype>
            <label>Created Transaction</label>
            <description>Internal ID of created transaction</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_create_transaction">
            <fieldtype>CHECKBOX</fieldtype>
            <label>Create Transaction</label>
            <description>Whether to create transaction on approval</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
            <defaultchecked>T</defaultchecked>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_rejection_reason">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Rejection Reason</label>
            <description>Reason for rejection</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_error_message">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Error Message</label>
            <description>Processing error message</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_uploaded_by">
            <fieldtype>SELECT</fieldtype>
            <label>Uploaded By</label>
            <description>User who uploaded the document</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
            <selectrecordtype>-4</selectrecordtype>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_created_date">
            <fieldtype>DATETIMETZ</fieldtype>
            <label>Created Date</label>
            <description>Date document was uploaded</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>T</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_modified_date">
            <fieldtype>DATETIMETZ</fieldtype>
            <label>Modified Date</label>
            <description>Date document was last modified</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_status_history">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Status History</label>
            <description>Status change history as JSON</description>
            <ismandatory>F</ismandatory>
            <displaytype>HIDDEN</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_user_corrections">
            <fieldtype>TEXTAREA</fieldtype>
            <label>User Corrections</label>
            <description>Manual corrections made by user as JSON</description>
            <ismandatory>F</ismandatory>
            <displaytype>HIDDEN</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_extracted_text">
            <fieldtype>TEXTAREA</fieldtype>
            <label>Extracted Text</label>
            <description>Full text extracted from document</description>
            <ismandatory>F</ismandatory>
            <displaytype>HIDDEN</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_extracted_data">
            <fieldtype>CLOBTEXT</fieldtype>
            <label>Extracted Data</label>
            <description>Complete extraction data as JSON - maps to any NetSuite field configured in form layout</description>
            <ismandatory>F</ismandatory>
            <displaytype>HIDDEN</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_processing_time">
            <fieldtype>INTEGER</fieldtype>
            <label>Processing Time (ms)</label>
            <description>Time taken to process document</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_email_sender">
            <fieldtype>EMAIL</fieldtype>
            <label>Email Sender</label>
            <description>Email address of sender</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_email_subject">
            <fieldtype>TEXT</fieldtype>
            <label>Email Subject</label>
            <description>Subject of source email</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>

        <customrecordcustomfield scriptid="custrecord_flux_email_received">
            <fieldtype>DATETIMETZ</fieldtype>
            <label>Email Received</label>
            <description>Date email was received</description>
            <ismandatory>F</ismandatory>
            <displaytype>NORMAL</displaytype>
            <showinlist>F</showinlist>
        </customrecordcustomfield>
    </customrecordcustomfields>
</customrecordtype>
